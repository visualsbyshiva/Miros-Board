# Miros API Configuration
# Copy this file to .env and fill in your actual values

# Your Miros API Key (get this from your Miros dashboard)
MIROS_API_KEY=YOUR_API_KEY_HERE

# Miros API Endpoint URL (usually this, but check Miros docs)
MIROS_API_URL=https://api.miros.services/graphql

# Your Miros Integration ID (you already have this)
MIROS_INTEGRATION_ID=fb97f7d4-fe95-402f-a81a-402cb062eaa3

# Port for your backend server (change if 3000 is taken)
PORT=3000

# Auth credentials — set these in Vercel environment variables
AUTH_USERNAME=admin
AUTH_PASSWORD=your-password-here
# Generate a random secret: openssl rand -hex 32
AUTH_SECRET=replace-with-a-long-random-string
